rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Default deny ──────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Helpers ─────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isGoogleSignIn() {
      return isSignedIn()
        && request.auth.token.firebase.sign_in_provider == 'google.com';
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userExists() {
      return isSignedIn() && exists(userPath());
    }

    function userData() {
      return get(userPath()).data;
    }

    function userRole() {
      return userExists() ? userData().role : null;
    }

    function userTempleId() {
      return userExists() ? userData().templeId : null;
    }

    function isOwner() {
      return userRole() == 'OWNER';
    }

    function isMentor() {
      return userRole() in ['MENTOR', 'OWNER'];
    }

    function isActiveUser() {
      return userExists() && userData().isDeleted != true;
    }

    function sameTemple(templeId) {
      return isActiveUser() && userTempleId() == templeId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role'])
        && data.email is string && data.email.size() <= 256
        && data.role in ['USER', 'MENTOR', 'OWNER']
        && !data.keys().hasAny(['password']);
    }

    function isValidDevotee(data) {
      return data.keys().hasAll(['name', 'contact'])
        && data.name is string && data.name.size() <= 100
        && data.contact is string && data.contact.size() <= 20
        && !data.keys().hasAny(['password']);
    }

    function isValidEvent(data) {
      return data.keys().hasAll(['title', 'date'])
        && data.title is string && data.title.size() <= 200
        && data.date is string;
    }

    function selfUpdateSafe() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['role', 'templeId', 'password', 'isDeleted', 'email']);
    }

    function eventDoc(eventId) {
      return get(/databases/$(database)/documents/events/$(eventId));
    }

    function eventAttendanceOpen(eventId) {
      return eventDoc(eventId).exists
        && eventDoc(eventId).data.isAttendanceOpen == true;
    }

    function publicFacilitatorRead() {
      return resource.data.keys().hasAll(['displayName', 'role', 'templeId'])
        && resource.data.role in ['MENTOR', 'OWNER']
        && resource.data.isDeleted != true;
    }

    // ── Connection test (dev only) ───────────────────────────────────────────
    match /test/{docId} {
      allow read: if true;
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow get: if isSignedIn() && (
        request.auth.uid == userId
        || (isMentor() && sameTemple(resource.data.templeId))
        || publicFacilitatorRead()
      );
      allow list: if (isSignedIn() && isMentor() && resource.data.templeId == userTempleId())
        || publicFacilitatorRead()
        || (!isSignedIn()
            && resource.data.templeId != null
            && resource.data.isDeleted != true
            && resource.data.keys().hasAll(['displayName', 'templeId']));
      allow create: if isSignedIn() && (
        (request.auth.uid == userId && isValidUser(incoming()) && incoming().role == 'USER')
        || (request.auth.uid == userId
            && isGoogleSignIn()
            && isValidUser(incoming())
            && incoming().role == 'OWNER'
            && incoming().templeId == request.auth.uid)
        || (isOwner() && isValidUser(incoming()) && incoming().templeId == userTempleId())
      );
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && selfUpdateSafe())
        || (isOwner() && sameTemple(resource.data.templeId)
            && incoming().templeId == resource.data.templeId
            && !incoming().keys().hasAny(['password']))
      );
      allow delete: if isOwner() && sameTemple(resource.data.templeId);
    }

    // ── Devotees ─────────────────────────────────────────────────────────────
    match /devotees/{devoteeId} {
      allow get, list: if isSignedIn() && sameTemple(resource.data.templeId);
      allow create: if isSignedIn() && isMentor()
        && isValidDevotee(incoming())
        && incoming().templeId == userTempleId();
      allow update: if isSignedIn() && isMentor()
        && sameTemple(resource.data.templeId)
        && incoming().templeId == resource.data.templeId
        && isValidDevotee(incoming());
      allow delete: if isOwner() && sameTemple(resource.data.templeId);

      // Public attendance: create/update when event attendance is open for same temple
      allow create, update: if isValidDevotee(incoming())
        && incoming().templeId is string
        && incoming().keys().hasAll(['_attendanceEventId'])
        && eventAttendanceOpen(incoming()._attendanceEventId)
        && eventDoc(incoming()._attendanceEventId).data.templeId == incoming().templeId
        && !incoming().keys().hasAny(['password', 'role']);
    }

    // ── Events ───────────────────────────────────────────────────────────────
    match /events/{eventId} {
      allow get: if resource.data.isAttendanceOpen == true
        || resource.data.isPublic == true
        || (isSignedIn() && sameTemple(resource.data.templeId));
      allow list: if isSignedIn() && isActiveUser() && resource.data.templeId == userTempleId();
      allow create: if isOwner() && isValidEvent(incoming())
        && incoming().templeId == userTempleId();
      allow update: if isOwner() && sameTemple(resource.data.templeId)
        && incoming().templeId == resource.data.templeId;
      allow delete: if isOwner() && sameTemple(resource.data.templeId);

      match /assignments/{assignmentId} {
        allow read: if isSignedIn() && sameTemple(eventDoc(eventId).data.templeId)
          || eventDoc(eventId).data.isPublic == true;
        allow list: if isSignedIn() && sameTemple(eventDoc(eventId).data.templeId);
        allow write: if isSignedIn() && isMentor()
          && sameTemple(eventDoc(eventId).data.templeId);
      }

      match /attendance/{attendanceDevoteeId} {
        allow read: if isSignedIn() && sameTemple(eventDoc(eventId).data.templeId)
          || eventAttendanceOpen(eventId);
        allow create, update: if eventAttendanceOpen(eventId)
          && incoming().keys().hasAll(['devoteeId', 'present'])
          || (isSignedIn() && isMentor() && sameTemple(eventDoc(eventId).data.templeId));
        allow delete: if isOwner() && sameTemple(eventDoc(eventId).data.templeId);
      }
    }

    // ── Templates ────────────────────────────────────────────────────────────
    match /templates/{templateId} {
      allow read: if isSignedIn() && sameTemple(resource.data.templeId);
      allow write: if isOwner() && incoming().templeId == userTempleId();
    }

    // ── Settings ───────────────────────────────────────────────────────────────
    match /settings/{templeId} {
      allow read: if isSignedIn() && userTempleId() == templeId;
      allow write: if isOwner() && userTempleId() == templeId;
    }

    // ── Calling history ────────────────────────────────────────────────────────
    match /callingHistory/{historyId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid
        || (isOwner() && sameTemple(resource.data.templeId))
      );
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isOwner() && sameTemple(resource.data.templeId);
    }

    // ── Duplicate facilitation conflicts ────────────────────────────────────────
    // Any signed-in temple member can read/create conflict docs (needed so
    // that whichever mentor/user's onSnapshot listener first notices a
    // cross-facilitator duplicate can write the shared notification doc).
    // Updating the candidate list while still pending is allowed for any
    // mentor in the temple (keeps the notification current if a third
    // facilitator adds the same devotee), but only the owner can actually
    // resolve a conflict (flip status to 'resolved'), since that is what
    // reassigns/removes devotee records.
    match /conflictAssignments/{conflictId} {
      allow read: if isSignedIn() && sameTemple(resource.data.templeId);
      allow create: if isSignedIn() && isMentor() && incoming().templeId == userTempleId();
      allow update: if isSignedIn() && sameTemple(resource.data.templeId) && (
        isOwner()
        || (isMentor() && resource.data.status == 'pending' && incoming().status == 'pending')
      );
    }

    // ── Temples / history ──────────────────────────────────────────────────────
    match /temples/{templeId} {
      allow read: if isSignedIn() && userTempleId() == templeId;
      allow write: if isOwner() && userTempleId() == templeId;

      match /history/{historyId} {
        allow read, write: if isOwner() && userTempleId() == templeId;
      }
    }

    // ── Collection group: assignments (profile view) ───────────────────────────
    match /{path=**}/assignments/{assignmentId} {
      allow read: if isSignedIn() && isActiveUser();
    }

    match /{path=**}/attendance/{attendanceId} {
      allow read: if isSignedIn() && isActiveUser();
    }
  }
}
