# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is gitignored.

# Firebase (from Firebase Console → Project settings → Your apps → Web app)
VITE_FIREBASE_API_KEY=your_firebase_web_api_key
# Local dev: use authDomain=localhost (Vite proxies /__/auth to Firebase — fixes Google OAuth)
# Production: use your-project.firebaseapp.com
VITE_FIREBASE_AUTH_DOMAIN=localhost
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
VITE_FIREBASE_DATABASE_ID=your-firestore-database-id

# Google account allowed on the Owner login tab
VITE_OWNER_EMAIL=your-owner@gmail.com

# CI / TestSprite — Owner password login (never enable in production)
VITE_ENABLE_TEST_LOGIN=false
VITE_OWNER_TEST_EMAIL=owner-test@example.com
VITE_OWNER_TEST_PASSWORD=use-a-strong-test-password-only

# Optional — Gemini AI features
GEMINI_API_KEY=[GCP_API_KEY]

# Secure your Firebase Web API key in Google Cloud Console:
# 1. APIs & Services → Credentials → Browser key (auto created by Firebase)
# 2. Application restrictions → HTTP referrers
# 3. Add: http://localhost:3000/* and your production domain/*
# 4. API restrictions → Restrict key → enable Identity Toolkit API + Firebase Installations API
